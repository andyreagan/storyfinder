storyFinder<-function(k,date,hour,minute){
	
	#source("/users/storyfinder/code/R/phraseShiftOnly.R")
	#source("/users/storyfinder/code/R/allForNothing.R")
	directory=paste("/users/storyfinder/data/",date,"/",hour,".",minute,sep="")

	entropyFile=paste(directory,"_entropy.csv",sep="")
	valenceFile=paste(directory,"_valence.csv",sep="")
	
	E_g<-read.csv(paste("/users/storyfinder/data/Boston_Entropy_Series.txt",sep=""),sep=",",dec=".",quote="\"",colClasses=c("numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","character","character","character"),header=F)
	V_g<-read.csv(paste("/users/storyfinder/data/Boston_Valence_Seires_000.txt",sep=""),sep=",",dec=".",quote="\"",colClasses=c("numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","numeric","character","character","character"),header=F)

	FILE=paste(directory,"_",as.character(k),"-storyFinder.pdf",sep="")
      pdf(file=FILE,9.7,7.5)
      
	#phraseShiftOnly(k,entropyFile,"Entropy",c(0,0.5,0,0.6))
	#phraseShiftOnly(k,valenceFile,"Valence",c(0.5,1,0,0.6))     

	allForNothing(k,entropyFile,"Entropy","",c(0,0.5,0,0.6))
        allForNothing(k,valenceFile,"Valence","",c(0.5,1,0,0.6))

      possibleIndices_day=which(E_g$V12==date)
	possibleIndices_hour=possibleIndices_day[which(E_g$V13[possibleIndices_day]==hour)]
	currentIndex=0
      currentIndex=currentIndex+possibleIndices_hour[which(E_g$V14[possibleIndices_hour]==minute)]

	E_timeseries=E_g[,k+1]
	V_timeseries=V_g[,k+1]
	
	E_timeseries_ALL=E_g[,1]
	V_timeseries_ALL=V_g[,1]				
		
	# start in on the time series plots
	dateIndices=which(V_g$V12==date)
	firstHour=min(dateIndices)
	plotIndices=c((firstHour-192):(firstHour-97),(firstHour-96):(firstHour-1),dateIndices)
	plotIndices=plotIndices[E_timeseries[plotIndices]>0]
	hourIndices=plotIndices[which(V_g$V14[plotIndices]=="59")]
	hourIndices=hourIndices[which(V_g$V13[hourIndices]!="23")]

	possibleMidnightIndices=which(V_g$V13 == "23")		
	midnightIndices=possibleMidnightIndices[which(V_g$V14[possibleMidnightIndices]=="59")]		

	par(las=2,fig=c(0.03,1,0.785,0.985),new=T)
	plot((1:length(E_timeseries))[plotIndices],E_timeseries[plotIndices],pch=20,xlab="",ylab="(bits)",main="Entropy timeseries",type="l",cex=0.5,xaxt='n',col="black",cex.axis=0.6)
	points(currentIndex,E_timeseries[currentIndex],pch=20,col='red',cex=1)
	
	
	if (length(midnightIndices)){
		for (i in 1:length(midnightIndices)){
                       lines(c(midnightIndices[i],midnightIndices[i]),c(-10,10),lty=3,col='red')
		}
	}

	if (length(hourIndices)){
		for (i in 1:length(hourIndices)){
		        lines(c(hourIndices[i],hourIndices[i]),c(-10,10),lty=3,col='grey')    
		}
	}
	
	par(las=2,fig=c(0.03,1,0.625,0.825),new=T)
	plot((1:length(V_timeseries))[plotIndices],V_timeseries[plotIndices],pch=20,xlab="",ylab="(happs)",main="Valence timeseries",type="l",cex=0.5,xaxt='n',col="black",cex.axis=0.6)
	points(currentIndex,V_timeseries[currentIndex],pch=20,col='red',cex=1)

	if (length(midnightIndices)){
		for (i in 1:length(midnightIndices)){
                        lines(c(midnightIndices[i],midnightIndices[i]),c(-10,10),lty=3,col='red')
        	}		
		axis(1,midnightIndices,V_g$V12[midnightIndices],las=2,cex.axis=0.6)		
	}
        if (length(hourIndices)){
                for (i in 1:length(hourIndices)){
                        lines(c(hourIndices[i],hourIndices[i]),c(-10,10),lty=3,col='grey')
                }
		axis(1,hourIndices,V_g$V13[hourIndices+1],las=2,cex.axis=0.6)
        }


	dev.off()

}